<% layout("/layouts/boilerplate.ejs")%>

<div class="row mt-3"> 
    <div class="col-6 offset-3"> 
        <h1>SignUp on Wanderlust</h1>
        <form action="/signup" method="POST" class="needs-validation" novalidate>

         <div class="mb-3"> 
            <label for="username" class="form-label">Username</label>
            <input id="username" name="username" placeholder="Enter username" type="text" class="form-control" required>
            <div class="invalid-feedback">Username should be Not Empty!</div>
             <div id="username" class="valid-feedback">Looks Good!</div>
         </div>

          <div class="mb-3"> 
            <label for="email" class="form-label">Email</label>
            <input id="email" name="email" placeholder="Enter Email" type="email" class="form-control" required>
            <div class="invalid-feedback">Email should be Not Empty!</div>
             <div id="email" class="valid-feedback">Looks Unique Email!</div>
         </div>

          <div class="mb-3"> 
            <label for="password" class="form-label">Password</label>
            <input id="password" name="password" placeholder="Enter Password" type="password" class="form-control" required>
            <div class="invalid-feedback">password should be Not Empty!</div>
             <div id="password" class="valid-feedback">Looks Good!</div>
         </div>

         <button class="btn btn-success">SignUp</button>
        </form>
   </div>
</div>