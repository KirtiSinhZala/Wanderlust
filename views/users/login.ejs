<% layout("/layouts/boilerplate.ejs")%>

<div class="row mt-3"> 
    <div class="col-6 offset-3"> 
        <h1>Login on Wanderlust</h1>
        <form action="/login" method="POST" class="needs-validation" novalidate>

         <div class="mb-3"> 

            <label for="username" class="form-label">Username</label>
            <input id="username" name="username" placeholder="Enter username" type="text" class="form-control" required>
            <div class="invalid-feedback">Username should be Not Empty!</div>
            
         </div>

        
          <div class="mb-3"> 
            <label for="password" class="form-label">Password</label>
            <input id="password" name="password" placeholder="Enter Password" type="password" class="form-control" required>
            <div class="invalid-feedback">password should be Not Empty!</div>
             
         </div>

         <button class="btn btn-success">Login</button>
    </form>
   </div>
</div>